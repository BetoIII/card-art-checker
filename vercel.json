{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' *.rocketlane.com"
        },
        {
          "key": "X-Frame-Options",
          "value": ""
        }
      ]
    }
  ],
  "functions": {
    "api/card-check.js": {
      "maxDuration": 300
    }
  }
}
