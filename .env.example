# Claude API — powers the managed agent that analyzes card art
ANTHROPIC_API_KEY=

# Rocketlane — pulls project info + uploads PDF reports to Space Documents
ROCKETLANE_API_KEY=

# Slack — posts compliance results to customer channels (ext-{name}-rain)
SLACK_BOT_TOKEN=

# Vercel Blob — stores generated PDF reports (permanent URLs for Rocketlane links)
BLOB_READ_WRITE_TOKEN=

# Claude Managed Agent — created by: node scripts/setup-agent.js
AGENT_ID=
ENV_ID=

# Anthropic Files API file ID for scripts/check_technical_specs.py
# Created by setup-agent.js — mounted into agent sessions at /mnt/session/scripts/
SPEC_SCRIPT_FILE_ID=
