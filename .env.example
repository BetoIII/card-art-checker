# Zap 1 webhook URL (Zapier "Webhooks by Zapier" catch hook)
ZAPIER_WEBHOOK_URL=

# Anthropic API key (for Claude Managed Agent + Files API)
ANTHROPIC_API_KEY=

# Vercel Blob read/write token (auto-set if provisioned via Vercel Marketplace)
BLOB_READ_WRITE_TOKEN=

# Claude Managed Agent ID (created once via API: POST /v1/agents)
MANAGED_AGENT_ID=

# Claude Managed Agent Environment ID (created once via API: POST /v1/environments)
MANAGED_AGENT_ENV_ID=
